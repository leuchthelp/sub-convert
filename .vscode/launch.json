{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Default",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
        },
        {
            "name": "Python Debugger: With options",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "args":  ["-d", "-o", "-cw", "4", "-ow", "4", "-lw", "3", "-p", "/workspaces/sup-convert/smb/jellyfin/shows/Arcane (2021)"]
        },
        {
            "name": "Python Debugger: Older/younger check",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "args":  ["-a", "s+1", "-s"]
        },
        {
            "name": "Python Debugger: Adjacent files check",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "args":  ["-s"]
        }
    ]
}